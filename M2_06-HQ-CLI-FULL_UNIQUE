#ЕСЛИ РАБОТАТЬ НЕ БУДЕТ - ВВЕДИ "rm -rf /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1" для удаления директории, и потом ВВЕДИ эти команды ниже:
for i in {1..5}; do
  mkdir -p /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]$i
  cp -r /etc/skel/. /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]$i/
  chown -R [ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]$i@[ИМЯ_ДОМЕНА]:domain\ users@[ИМЯ_ДОМЕНА] /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]$i
done
