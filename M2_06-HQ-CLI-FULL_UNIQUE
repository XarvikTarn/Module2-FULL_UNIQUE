#Preparing HQ-CLI for configuration
sed -i 's|http://ftp.altlinux.org/pub/distributions/ALTLinux|http://10.45.33.250:3142/altlinux|g' /etc/apt/sources.list.d/alt.list
cat <<EOF > /etc/openssh/sshd_config
Port 22
PermitRootLogin yes
Subsystem sftp /usr/lib/openssh/sftp-server
EOF
systemctl enable --now sshd
echo "nameserver 77.88.8.8" > /etc/resolv.conf
apt-get update && apt-get install -y chrony task-auth-ad-sssd libnss-role

#Setting up NTP-Client
sed -i '/pool/d' /etc/chrony.conf
sed -i '/server/d' /etc/chrony.conf
echo "server 172.16.1.1 iburst prefer" >> /etc/chrony.conf
systemctl restart chronyd
sleep 3 && chronyc sources

#Setting up Samba-DC Client
nmcli c show --active
nmcli con mod "DHCP-CLI" ipv4.dns "192.168.3.10"
nmcli con mod "DHCP-CLI" ipv4.ignore-auto-dns yes
nmcli con up "DHCP-CLI"
system-auth write ad [ИМЯ_ДОМЕНА] hq-cli [ИМЯ_ДОМЕНА_КРАТКО] administrator P@ssw0rd
systemctl restart sssd
sleep 3
control libnss-role enabled
roleadd [ИМЯ_ГРУППЫ] wheel
cat <<EOF > /etc/sudoers.d/[ИМЯ_ГРУППЫ]_restrictions
Cmnd_Alias [ИМЯ_ГРУППЫ]_CMDS = /bin/cat, /bin/grep, /usr/bin/id
%wheel ALL=(ALL) NOPASSWD: [ИМЯ_ГРУППЫ]_CMDS
EOF


#ВВОДИ ЭТИ 4 КОМАНДЫ СТРОГО ПО 1 СТРОКЕ - ПОСЛЕ "su - [ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1" ВВЕДИ пароль P@ssw0rd для входа, а потом "sudo id" И "sudo reboot" (ошибка должна быть, всё норм) - ПОТОМ ВВЕДИ "exit" И ПОСЛЕ "exit" ДЕЛАЙ ОСТАЛЬНЫЕ КОМАНДЫ
mkdir -p /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1
\cp -af /etc/skel/. /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1/
chown -R [ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1:[ИМЯ_ГРУППЫ] /home/[ИМЯ_ДОМЕНА_CAPS]/[ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1
su - [ПОЛЬЗОВАТЕЛЬ_ГРУППЫ]1

