#Preparing ISP for configuration
sed -i 's|http://ftp.altlinux.org/pub/distributions/ALTLinux|http://10.45.33.250:3142/altlinux|g' /etc/apt/sources.list.d/alt.list
cat <<EOF > /etc/nftables/nftables.nft
#!/usr/sbin/nft -f
flush ruleset
table ip nat {
    chain postrouting {
        type nat hook postrouting priority srcnat;
        oifname "enp7s1" masquerade
    }
}
table ip filter {
    chain forward {
        type filter hook forward priority 0;
        tcp flags syn tcp option maxseg size set 1400
    }
}
EOF
systemctl restart nftables
apt-get update && apt-get install -y chrony

#Setting up NTP-Server
cat <<EOF >> /etc/chrony.conf
local stratum [NTP_STRATUM]
allow all
EOF
systemctl enable --now chronyd
systemctl restart chronyd & sleep 3
ss -ulnp | grep 123
chronyc tracking

#Setting up Nginx-Client
ssh -p [SSH_ПОРТ] root@172.16.1.10
#ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО ВАЖНО - КОПИРУЙ-ВСТАВЬ ЛИШЬ "ssh -p [SSH_ПОРТ] root@172.16.1.10" - если спросит (yes/no) - пропиши "no". ПОТОМ копируй всё что ниже, это чисто для проверки.
apt-get update && apt-get install -y nginx apache2 curl
htpasswd -bc /etc/nginx/.htpasswd [LAMP_ПОЛЬЗОВАТЕЛЬ_CAPS] [LAMP_ПАРОЛЬ]
cat <<EOF > /etc/nginx/sites-available.d/web.conf
server {
    listen 80;
    server_name web.[ИМЯ_ДОМЕНА];
    location / {
        proxy_pass http://172.16.1.10:8080;
        proxy_set_header Host \$host;
        auth_basic "Restricted Area";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }
}
EOF
cat <<EOF > /etc/nginx/sites-available.d/docker.conf
server {
    listen 80;
    server_name docker.[ИМЯ_ДОМЕНА];
    location / {
        proxy_pass http://172.16.2.10:[ПОРТ_DOCKER-ПРИЛОЖЕНИЯ];
        proxy_set_header Host \$host;
    }
}
EOF
ln -s /etc/nginx/sites-available.d/web.conf /etc/nginx/sites-enabled.d/web.conf
ln -s /etc/nginx/sites-available.d/docker.conf /etc/nginx/sites-enabled.d/docker.conf
systemctl enable --now nginx
nginx -t
systemctl restart nginx
ls -l /etc/nginx/sites-enabled.d/
echo "127.0.0.1 web.[ИМЯ_ДОМЕНА] docker.[ИМЯ_ДОМЕНА]" >> /etc/hosts
curl http://docker.[ИМЯ_ДОМЕНА] | head -n 10
curl -I http://web.[ИМЯ_ДОМЕНА]
curl -u [LAMP_ПОЛЬЗОВАТЕЛЬ_CAPS]:[LAMP_ПАРОЛЬ] http://web.[ИМЯ_ДОМЕНА] | head -n 10
history -a
